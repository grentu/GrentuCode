{
  "name": "@grentu/grentu",
  "version": "0.7.3",
  "description": "Grentu Code — AI coding agent for the terminal",
  "type": "module",
  "bin": {
    "grentu": "bin/grentu.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "start": "node bin/grentu.js",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "cli",
    "coding-agent",
    "terminal",
    "tui",
    "llm",
    "openai",
    "anthropic",
    "gemini",
    "assistant",
    "developer-tools"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "@google/generative-ai": "^0.24.1",
    "chalk": "^5.4.1",
    "cli-cursor": "^4.0.0",
    "ink": "^5.0.1",
    "openai": "^4.77.0",
    "react": "^18.3.1",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@typescript-eslint/eslint-plugin": "^8.21.0",
    "@typescript-eslint/parser": "^8.21.0",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3"
  }
}
